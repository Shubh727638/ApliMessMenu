{\n  "name": "apli-mess-menu-full",\n  "version": "1.0.0",\n  "description": "This Project help to find mess menu for student and all other people",\n  "private": true,\n  "scripts": {\n    "install-all": "npm install && cd Backend && npm install && cd ../FrontEnd && npm install && cd ..",\n    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",\n    "start:backend": "cd Backend && node index.js",\n    "start:backend:dev": "cd Backend && nodemon index.js",\n    "start:frontend": "cd FrontEnd && npm start",\n    "build": "cd FrontEnd && npm run build",\n    "dev": "concurrently \"npm run start:backend:dev\" \"npm run start:frontend\""\n  },\n  "devDependencies": {\n    "concurrently": "^8.2.2"\n  }\n}